
from http.server import BaseHTTPRequestHandler, HTTPServer
import json
import os
import random
import string

PORT = int(os.environ.get("PORT", 3000))
DB_FILE = "users.json"

# Load users
def load_users():
    if not os.path.exists(DB_FILE):
        return {}
    with open(DB_FILE, "r") as f:
        return json.load(f)

# Save users
def save_users(users):
    with open(DB_FILE, "w") as f:
        json.dump(users, f)

# Generate key
def generate_key():
    return ''.join(random.choices(string.ascii_letters + string.digits, k=8))

users = load_users()

class handler(BaseHTTPRequestHandler):

    def do_GET(self):

        # Home
        if self.path == "/":
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"🚀 Trading Bot Running")

        # Signal (locked)
        elif self.path.startswith("/api/signal"):
            from urllib.parse import urlparse, parse_qs

            query = parse_qs(urlparse(self.path).query)
            key = query.get("key", [None])[0]

            user = users.get(key)

            if not user or not user["paid"]:
                self.send_response(403)
                self.end_headers()
                self.wfile.write(json.dumps({
                    "error": "Access denied. Pay first."
                }).encode())
                return

            score = random.randint(1, 100)

            if score > 70:
                signal = "BUY"
            elif score < 30:
                signal = "SELL"
            else:
                signal = "HOLD"

            response = {
                "user": user["name"],
                "signal": signal,
                "confidence": score
            }

            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(response).encode())

        # Create user
        elif self.path.startswith("/create-user"):
            from urllib.parse import urlparse, parse_qs

            query = parse_qs(urlparse(self.path).query)
            name = query.get("name", ["user"])[0]

            key = generate_key()

            users[key] = {
                "name": name,
                "paid": False
            }

            save_users(users)

            self.send_response(200)
            self.end_headers()
            self.wfile.write(json.dumps({
                "name": name,
                "key": key
            }).encode())

        # Activate user
        elif self.path.startswith("/activate"):
            from urllib.parse import urlparse, parse_qs

            query = parse_qs(urlparse(self.path).query)
            key = query.get("key", [None])[0]

            if key in users:
                users[key]["paid"] = True
                save_users(users)

                self.send_response(200)
                self.end_headers()
                self.wfile.write(json.dumps({
                    "message": "Activated"
                }).encode())
            else:
                self.send_response(404)
                self.end_headers()
                self.wfile.write(b"User not found")

        else:
            self.send_response(404)
            self.end_headers()
            self.wfile.write(b"Not Found")


HTTPServer(("0.0.0.0", PORT), handler).serve_forever()
